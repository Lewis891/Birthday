{
    "name": "11ty-template",
    "version": "1.0.0",
    "description": "Reusable Eleventy + Netlify + SASS starter template",
    "main": "index.js",
    "scripts": {
        "start": "cross-env ELEVENTY_ENV=DEV eleventy --serve",
        "build": "cross-env ELEVENTY_ENV=PROD eleventy",
        "preview": "cross-env ELEVENTY_ENV=PROD eleventy --serve",
        "create-page": "node scripts/create-page.js"
    },
    "dependencies": {
        "@11ty/eleventy": "^3.1.2",
        "@codestitchofficial/eleventy-plugin-minify": "^1.1.3",
        "@codestitchofficial/eleventy-plugin-sharp-images": "^2.2.0",
        "@quasibit/eleventy-plugin-sitemap": "^2.2.0",
        "autoprefixer": "^10.4.27",
        "cross-env": "^10.1.0",
        "cssnano": "^7.1.2",
        "esbuild": "^0.27.3",
        "glob": "^13.0.6",
        "netlify-plugin-cache": "^1.0.3",
        "postcss": "^8.5.8",
        "sass": "^1.97.3"
    }
}
